.index-card
  margin-bottom 2.5rem

.index-img
  img
    display block
    width 100%
    height 10rem
    object-fit cover
    box-shadow 0 5px 11px 0 rgba(0, 0, 0, 0.18), 0 4px 15px 0 rgba(0, 0, 0, 0.15)
    border-radius .25rem
    background-color transparent

.index-info
  display flex
  flex-direction column
  justify-content space-between
  padding-top .5rem
  padding-bottom .5rem

.index-header
  color var(--text-color)
  font-size 1.5rem
  font-weight bold
  line-height 1.4
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  margin-bottom .25rem

  .index-pin
    color var(--text-color)
    font-size 1.5rem
    margin-right .15rem

.paper-label {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 25px;
  font-weight: 500;
  font-size: 0.8rem;
  width: max-content;
  margin-bottom: 0.45rem;
}

.paper-label span {
  display: inline-block;
}

.paper-label.conference {
  background-color: #ff4d4d; 
  border: 1px solid #cc0000; 
  color: white;
}

.paper-label.journal {
  background-color: #fff176;
  border: 1px solid #fbc02d;
  color: black;
}

.short-conf-label {
  background-color: #f5f5f5;
  border: 1px solid #ddd;
  color: #555;
}
.short-journal-label {
  background-color: #4fc978;
  border: 1px solid #588e6a;
  color: #fff;
}

.date-label {
  display: inline-block;       
  padding: 6px 12px;           
  border-radius: 25px;          
  font-weight: 500;
  font-size: 0.8rem;
  background-color: #b3e5fc;  
  border: 1px solid #0288d1;  
  color: #01579b;             
}

.date-label i {
  margin-right: 4px;           
  vertical-align: middle;      
}

.index-btm
  color var(--sec-text-color)

  a
    color var(--sec-text-color)

.index-excerpt
  color var(--sec-text-color)
  margin 0.5rem 0
  overflow hidden
  display flex

  & > div
    width 100%
    line-height 1.4rem
    word-break break-word
    display -webkit-box
    -webkit-box-orient vertical
    -webkit-line-clamp 3

.index-excerpt__noimg
  height auto

@media (max-width: 767px)
  .index-info
    padding-top 1.25rem

  .index-header
    font-size 1.25rem
    white-space normal
    overflow hidden
    word-break break-word
    display -webkit-box
    -webkit-box-orient vertical
    -webkit-line-clamp 2

    .index-pin
      font-size 1.25rem

  .index-excerpt
    height auto
    margin 0.25rem 0
